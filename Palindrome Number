class Solution:
    def isPalindrome(self, x: int) -> bool:
        if x < 0:
            return False
        elif x == 0:
            return True 
        x_notrev = x
        x_rev = 0
        c = len(str(x))-1
        while x > 0:
            rem = x%10
            x_rev += rem*(10**c)
            x //= 10
            c -= 1
        if x_notrev == x_rev:
            return True
        else:
            return False   
