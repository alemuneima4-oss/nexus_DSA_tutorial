class Solution:
    def commonChars(self, words: List[str]) -> List[str]:
        result = []
        for i in words[0]:
            for j in range(1,len(words)-1):
                if i in words[j] and i in words[j+1]:
                    words[j] = words[j].replace(i,"",1)
                    words[j+1] = words[j+1].replace(i,"",1)    
                    result += i
        return result
