# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def middleNode(self, head: Optional[ListNode]) -> Optional[ListNode]:
        count = 0
        node = head
        while node != None:
            node = node.next
            count += 1
        mid_index = count //2
        index = 0
        node = head
        while index != mid_index:
            node = node.next
            index += 1
        return node
        
